{
  "name": "fb-marketplace-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "run": "tsx src/cli.ts run",
    "run:catalog": "tsx src/cli.ts run --catalog ./runtime/topic-catalog.json",
    "run:topic": "tsx src/cli.ts run --topic ./config/topics/golf-premium-topic.json",
    "run:legacy": "tsx src/cli.ts run --config ./config/search-profiles.json",
    "run:mock": "tsx src/cli.ts run --mock ./mock-data/sample-run.json",
    "catalog:build": "tsx src/cli.ts build-catalog",
    "research:build": "tsx src/cli.ts build-research-config",
    "db:init": "tsx src/cli.ts init-db"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.5",
    "playwright": "^1.53.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
